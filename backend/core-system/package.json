{
  "name": "core",
  "version": "1.0.0",
  "description": "Core backend: user/co-host API and RBAC (no Telegram dependency)",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsup && node dist/swagger.js --generate-only",
    "typecheck": "tsc --noEmit",
    "start": "node dist/swagger.js",
    "dev": "tsx src/swagger.ts",
    "dev:watch": "nodemon --exec tsx src/swagger.ts",
    "dev:watch:public": "nodemon --exec ENTRY_POINT=public tsx src/swagger.ts",
    "dev:watch:private": "nodemon --exec ENTRY_POINT=private tsx src/swagger.ts",
    "server": "node dist/server.js",
    "server:public": "ENTRY_POINT=public node dist/swagger.js",
    "server:private": "ENTRY_POINT=private node dist/swagger.js",
    "swagger": "tsx src/swagger.ts --generate-only",
    "generate-salt": "node dist/scripts/generate-salt.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.6",
    "@types/swagger-ui-express": "^4.1.6",
    "nodemon": "^3.1.9",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "core",
    "rest-api",
    "nodejs",
    "express",
    "postgresql",
    "typescript"
  ],
  "author": "",
  "license": "MIT"
}
