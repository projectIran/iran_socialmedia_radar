PORT=3000
# Entry point: full (default) | public | private. Use public/private for two-container deploy.
# ENTRY_POINT=full
# Public base URL of the API (Swagger "Try it out", CORS, etc.). No trailing slash.
# BASE_URL=https://api.yourdomain.com
DATABASE_URL=postgresql://user:password@localhost:5432/core_db

# Admins: comma-separated emails and/or user IDs. Legacy single values ADMIN_EMAIL and ADMIN_USER_ID still work.
ADMIN_EMAILS=admin@example.com,other@example.com
# ADMIN_USER_IDS=uuid1,uuid2
# Or single (legacy):
# ADMIN_EMAIL=admin@example.com
# ADMIN_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

JWT_SECRET=your-secret-at-least-32-chars-long
JWT_EXPIRES_IN=7d

# Optional: encrypt co_hosts data in DB (same pattern as Telegram bot)
# COHOST_ENCRYPTION_KEY=

# Optional: salt for hashWithSalt / hashUserId (change in production)
# HASH_SALT=

# Optional: URL shortener for email campaign mailto links (shortio | bitly | tinyurl). If unset, mailto is stored as-is.
# URL_SHORTENER_API_KEY=
# URL_SHORTENER_PROVIDER=shortio
# URL_SHORTENER_DOMAIN=go.example.com

# Optional: AI for email personalization (e.g. openai, groq). If unset, generate-email may return base subject/body.
# AI_API_KEY=
# AI_PROVIDER=openai
